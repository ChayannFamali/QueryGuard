# QueryGuard — local dev environment variables
# Copy this to .env and fill in real values
# NEVER commit .env to version control

POSTGRES_PASSWORD=changeme-local-only
PGADMIN_DEFAULT_PASSWORD=changeme-local-only
GF_SECURITY_ADMIN_PASSWORD=changeme-local-only
QG_DASHBOARD_USERNAME=admin
QG_DASHBOARD_PASSWORD=changeme-local-only
QG_METRICS_USERNAME=metrics
QG_METRICS_PASSWORD=changeme-local-only

# Integration test DSN (optional — defaults to localhost:5433)
# PROXY_DSN=postgres://user:pass@localhost:5433/mydb?sslmode=disable
